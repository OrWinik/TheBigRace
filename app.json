{
  "expo": {
    "name": "TheBigRace",
    "slug": "TheBigRace",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LogoW.png",
    "scheme": "TheBigRace",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.OrWinik.TripTailor",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "The Big Race uses your camera to capture mission photos and videos required to complete race challenges, and to set your profile picture.",
        "NSMicrophoneUsageDescription": "The Big Race uses your microphone to record short videos during race challenges that require video submissions.",
        "NSPhotoLibraryUsageDescription": "The Big Race uses your photo library to let you upload existing photos for mission submissions and to set your profile picture from your camera roll."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/LogoW.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.OrWinik.TripTailor"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/LogoW.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1825fdf-9930-4b2e-abe8-749a4d4bd519"
      }
    }
  }
}